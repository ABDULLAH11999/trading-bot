PAPER_TRADING=true
FORCE_SECURE_COOKIES=false
ENABLE_API_DOCS=false
ENABLE_STARTUP_SECURITY_SCAN=false

# Use a long random value in production.
AUTH_SESSION_SECRET=change-me
APP_ENCRYPTION_SECRET=change-me-too
PUBLIC_APP_URL=http://127.0.0.1:8000

# Mail delivery for registration verification emails
# On free Render, prefer an HTTPS provider API instead of SMTP.
MAIL_PROVIDER=resend
RESEND_API_KEY=
# Use a sender allowed by Resend.
# For quick testing you can use onboarding@resend.dev.
# For production, verify your domain in Resend and use that address.
MAIL_FROM_ADDRESS=onboarding@resend.dev
MAIL_FROM_NAME=Scalper Bot

# Or use Brevo instead:
# MAIL_PROVIDER=brevo
# BREVO_API_KEY=
# SMTP remains available as a fallback for local/self-hosted environments.
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password
MAIL_ENCRYPTION=tls

# Stripe test or live keys
STRIPE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET=sk_test_xxxxxxxxxxxxxxxxxxxxx
REAL_MODE_FEE=29
ADMIN_EMAIL=admin@example.com
ADMIN_PASS=change-me

# Legacy fallback keys. The UI now expects users to save test/real keys per account.
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=
BINANCE_API_KEY=
BINANCE_API_SECRET=
